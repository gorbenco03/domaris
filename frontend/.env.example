# ================================================================
# RIVA Frontend — Environment Variables
# Copy this file to .env.local and fill in your values.
# All NEXT_PUBLIC_* variables are exposed to the browser bundle.
# ================================================================

# ----------------------------------------------------------------
# Backend API
# ----------------------------------------------------------------

# Base URL of the RIVA backend API (without trailing slash)
# Example: https://api.riva.md/api
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# WebSocket URL (defaults to API_URL with /api stripped and ws:// prefix)
# Only set explicitly if your WS server runs on a different host/port
# NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ----------------------------------------------------------------
# Mapbox GL JS
# ----------------------------------------------------------------

# Mapbox public access token (https://account.mapbox.com/access-tokens/)
# Required for the property map to render
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJZT1VSX1RPS0VOIn0.XXXXXXXXXX

# ----------------------------------------------------------------
# Environment / build mode
# ----------------------------------------------------------------

# One of: development | staging | production
# Affects debug logging and analytics
NEXT_PUBLIC_ENV=development

# ----------------------------------------------------------------
# Feature flags
# ----------------------------------------------------------------

# Enable subscription / promote / pricing pages (monetization).
# Set to "true" only when payment integration is ready.
# Default: not set / false — all monetization UI is hidden.
NEXT_PUBLIC_MONETIZATION_ENABLED=false

# Enable Google OAuth login button.
# Set to "true" only when the OAuth callback is wired up on the backend.
# Default: not set / false — button is hidden.
NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=false
