NODE_ENV=production
APP_NAME=hatch
API_URL=https://YOUR-BACKEND-DOMAIN/api
APP_URL=https://YOUR-FRONTEND-DOMAIN

DB_DIALECT=postgres
DB_HOST=${{Postgres.PGHOST}}
DB_PORT=${{Postgres.PGPORT}}
DB_USER=${{Postgres.PGUSER}}
DB_PASS=${{Postgres.PGPASSWORD}}
DB_NAME=${{Postgres.PGDATABASE}}
DB_LOGGING=false
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false
DB_SYNCHRONIZE=false

EXPO_ACCESS_TOKEN=YOUR_EXPO_ACCESS_TOKEN

APP_MAINTENANCE=false
APP_MAINTENANCE_MESSAGE="Momentan aplicatia este in mentenanta. Revino in curand."
APP_MIN_VERSION_IOS=1.0.0
APP_MIN_VERSION_ANDROID=1.0.0
APP_LATEST_VERSION_IOS=1.0.3
APP_LATEST_VERSION_ANDROID=1.0.3
APP_STORE_URL_IOS=https://apps.apple.com/...
APP_STORE_URL_ANDROID=https://play.google.com/store/apps/details?id=...

DO_SPACES_ACCESS_KEY_ID=YOUR_DO_SPACES_ACCESS_KEY_ID
DO_SPACES_SECRET_ACCESS_KEY=YOUR_DO_SPACES_SECRET_ACCESS_KEY
DO_SPACES_REGION=fra1
DO_SPACES_BUCKET=domaris

APPLE_CLIENT_ID=YOUR_APPLE_CLIENT_ID
APPLE_AUDIENCE=ro.riva.app
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID

JWT_SECRET=YOUR_LONG_RANDOM_JWT_SECRET
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o
APIFY_TOKEN=YOUR_APIFY_TOKEN

MAPBOX_SECRET_TOKEN=YOUR_MAPBOX_SECRET_TOKEN

REDIS_HOST=${{Redis.REDISHOST}}
REDIS_PORT=${{Redis.REDISPORT}}
REDIS_PASSWORD=${{Redis.REDISPASSWORD}}

EMAIL_PROVIDER=console
EMAIL_FROM=noreply@domaris.ro
EMAIL_FROM_NAME=Domaris
SENDGRID_API_KEY=
AWS_SES_REGION=

SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

PUSH_PROVIDER=expo
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

DEFAULT_CURRENCY=MDL

PAYNET_MERCHANT_ID=
PAYNET_SECRET_KEY=
PAYNET_API_URL=https://sandbox.paynet.md/api/v1

MAIB_MERCHANT_ID=
MAIB_TERMINAL_ID=
MAIB_CERT_PATH=
MAIB_KEY_PATH=
MAIB_API_URL=https://ecomm-test.maib.md

MPAY_MERCHANT_ID=
MPAY_SECRET_KEY=
MPAY_API_URL=https://sandbox.mpay.md/api/v1

APPLE_IAP_SHARED_SECRET=
APPLE_IAP_ISSUER_ID=
APPLE_IAP_KEY_ID=
APPLE_IAP_PRIVATE_KEY_PATH=
APPLE_IAP_ENV=sandbox

GOOGLE_PLAY_PACKAGE_NAME=com.domaris.app
GOOGLE_PLAY_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY_PATH=
