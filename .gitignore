# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist/
tmp/
out-tsc/
coverage/
test-output/
out/
.next/

# dependencies
node_modules/

# package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env files and secrets
.env
.env.*
!.env.example
!.env.*.example
backend/.env
backend/.env.railway
mobile/.env.local

# IDEs and editors
.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
.sass-cache/
connect.lock
libpeerconnection.log
testem.log
typings/
tsconfig.tsbuildinfo

# system files
.DS_Store
Thumbs.db

# nx
.nx/cache/
.nx/workspace-data/

# local tool metadata
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md
.claude/

# python venv for the ML/AVM pipeline (heavy, regenerable)
ml/.venv/

# thesis (LaTeX document) — uploaded separately as PDF, not part of the app source repo
thesis/

# expo / react native
.expo/
.expo-shared/
expo-env.d.ts

# iOS
mobile/ios/Pods/
mobile/ios/build/
mobile/ios/.symlinks/
mobile/ios/DerivedData/
mobile/ios/*.xcworkspace/xcuserdata/
mobile/ios/*.xcodeproj/xcuserdata/
mobile/ios/**/*.xcuserstate

# Android
mobile/android/.gradle/
mobile/android/build/
mobile/android/app/build/
mobile/android/local.properties
mobile/android/.cxx/

# generated native artifacts that should not be committed
mobile/android/app/debug/
mobile/android/app/release/
/mobile/ios/
/mobile/android/
